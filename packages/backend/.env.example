# Upstash Redis (nullifier + token storage)
UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token_here

# Venice AI (or any OpenAI-compatible provider)
VENICE_API_KEY=your_venice_api_key_here
# VENICE_BASE_URL=https://api.venice.ai/api/v1  # change to use a different provider
# VENICE_MODEL=zai-org-glm-5                    # default model
# VENICE_E2EE_MODEL=e2ee-glm-5                  # E2EE model

# Contract (Base mainnet)
CONTRACT_ADDRESS=0x595463222a592416BCbdADb297Bf7D050c09a44E
CHAIN_ID=8453
RPC_URL=https://base-mainnet.g.alchemy.com/v2/your_alchemy_key_here
# WS_URL=wss://base-mainnet.g.alchemy.com/v2/your_alchemy_key_here  # WebSocket for real-time events

# Server
PORT=3001
NODE_ENV=development
# COST_MULTIPLIER=1.0  # multiplier applied to Venice usage cost
