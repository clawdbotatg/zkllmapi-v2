# Upstash Redis (nullifier + token storage)
UPSTASH_REDIS_REST_URL=https://pro-hare-79343.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_TOKEN

# API Server
API_URL=http://localhost:3001

# Wallet — must be a funded Base wallet with ETH (for gas) + CLAWD (for buying credits)
# Get private key from: security find-generic-password -s "your-key-name" -a "your-account" -w
# IMPORTANT: this wallet pays for onchain credit purchases — it needs ETH + CLAWD balance
WALLET_PRIVATE_KEY=YOUR_PRIVATE_KEY_HERE

# Proxy
PORT=3100
BUY_THRESHOLD=1
BUY_CHUNK=1
